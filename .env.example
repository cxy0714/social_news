# 复制为 .env 并填写。`.env` 已在 .gitignore 中忽略，绝不入库。
# 本文件仅供「本地 API 版每日 digest」(scripts/generate_digest.py) 使用。
# 云端 Claude 定时任务不读它。

# ─── Provider 选择 ─────────────────────────────────────────────────────
# deepseek | claude —— 一个开关切换整套 LLM 后端，默认走 DeepSeek(便宜)。
LLM_PROVIDER=deepseek

# ─── DeepSeek(默认) ───────────────────────────────────────────────────
# 官方: https://api.deepseek.com
# 交大网关(内网/校园网可达): https://models.sjtu.edu.cn/api/v1
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_KEY=sk-replace-me
DEEPSEEK_MODEL=deepseek-chat

# ─── Claude(Anthropic 官方 API) ───────────────────────────────────────
# 独立付费 key，与 Claude Code 订阅无关。切到这个 provider 才需要填。
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-opus-4-8

# ─── 通用请求参数 ──────────────────────────────────────────────────────
# 单次 LLM 请求超时(秒) / 最大重试次数。摘要任务偶尔会卡长，默认放宽。
LLM_TIMEOUT=180
LLM_MAX_ATTEMPTS=3
