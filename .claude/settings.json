{
  "permissions": {
    "allow": [
      "Bash(python3 scripts/fetch_news.py)",
      "Bash(python scripts/fetch_news.py)",
      "WebFetch(domain:github.com)",
      "Bash(gh repo *)",
      "Bash(gh api *)",
      "Bash(curl -s \"https://api.github.com/repos/cxy0714/research-news/git/trees/main?recursive=1\")",
      "Bash(timeout 120 python scripts/generate_digest.py --dry-run --hours 48)",
      "Bash(rm -rf scripts/__pycache__)",
      "Bash(git check-ignore *)",
      "Bash(python -c ' *)",
      "Bash(timeout 560 python scripts/build_eval.py --hours 24)",
      "Bash(ls -la evals/)",
      "Bash(head -12 evals/2026-07-10.md)",
      "Bash(mkdir -p logs)",
      "Bash(nohup python scripts/build_eval.py --hours 24)",
      "Bash(echo \"started PID=$!\")",
      "Bash(head -25 future-tech/README.md)",
      "Bash(tail -8 logs/eval-run.log)",
      "Bash(cat logs/eval-run.log)",
      "Bash(ls evals/*.md)",
      "Bash(powershell.exe -NoProfile -Command 'Get-CimInstance Win32_Process -Filter \"name='\\\\''python.exe'\\\\''\" | Where-Object {$_.CommandLine -like '\\\\''*build_eval*'\\\\''} | Select-Object ProcessId, CreationDate | Format-List')",
      "Bash(python -m py_compile web/build.py)",
      "Bash(python -c \"import markdown\")",
      "Bash(powershell.exe -NoProfile -Command '$p = Get-CimInstance Win32_Process -Filter \"name='\\\\''python.exe'\\\\''\" | Where-Object {$_.CommandLine -like '\\\\''*build_eval*'\\\\''}; if \\($p\\) { Write-Host '\\\\''ALIVE PID'\\\\'' $p.ProcessId '\\\\''started'\\\\'' $p.CreationDate } else { Write-Host '\\\\''NOT RUNNING'\\\\'' }')",
      "Bash(timeout 90 python -c ' *)",
      "Bash(python scripts/build_eval.py --hours 24)",
      "Bash(python -m py_compile scripts/build_eval.py)",
      "Bash(python -m py_compile scripts/llm_client.py)",
      "Bash(pip install *)",
      "Bash(python web/build.py)",
      "Bash(rm -rf scripts/__pycache__ web/__pycache__)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
